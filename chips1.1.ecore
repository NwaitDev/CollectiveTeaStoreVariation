        </eClassifiers>
        <eClassifiers xsi:type="ecore:EClass" name="physical_collective_cast" eSuperTypes="#//systemspecific/int_physical_feeder #//systemspecific/float_physical_feeder #//systemspecific/bool_physical_feeder">
