        </eClassifiers>
        <eClassifiers xsi:type="ecore:EClass" name="logical_collective_cast" eSuperTypes="#//systemspecific/int_logical_feeder #//systemspecific/float_logical_feeder #//systemspecific/bool_logical_feeder">
          <eStructuralFeatures xsi:type="ecore:EReference" name="logical_feeder_expression"
