<?xml version="1.0" encoding="UTF-8"?>
<ecore:EPackage xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" name="chips" nsURI="http://chips" nsPrefix="chips">
  <eClassifiers xsi:type="ecore:EClass" name="program">
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="fileName" lowerBound="1"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="preamble" eType="#//preamble_section"
        containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="system" eType="#//system_section"
        containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="system_section">
    <eStructuralFeatures xsi:type="ecore:EReference" name="system" upperBound="-1"
        eType="#//statements/system_statement" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="preamble_section">
    <eStructuralFeatures xsi:type="ecore:EReference" name="definitions" upperBound="-1"
        eType="#//definitions/definition" containment="true"/>
  </eClassifiers>
  <eSubpackages name="variables" nsURI="http://chips/variables" nsPrefix="chips.variables">
    <eClassifiers xsi:type="ecore:EClass" name="array">
      <eTypeParameters name="appropriate_int_rvalue"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="dimensions" upperBound="-1"
          containment="true">
        <eGenericType eTypeParameter="#//variables/array/appropriate_int_rvalue"/>
      </eStructuralFeatures>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="variable" abstract="true">
      <eTypeParameters name="appropiate_int_rvalue"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" lowerBound="1"
          eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
      <eGenericSuperTypes eClassifier="#//variables/array">
        <eTypeArguments eTypeParameter="#//variables/variable/appropiate_int_rvalue"/>
      </eGenericSuperTypes>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="primitive_variable" abstract="true">
      <eGenericSuperTypes eClassifier="#//variables/variable">
        <eTypeArguments eClassifier="#//rvalues/primitive_int_rvalue"/>
      </eGenericSuperTypes>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="node_variable" abstract="true">
      <eGenericSuperTypes eClassifier="#//variables/variable">
        <eTypeArguments eClassifier="#//rvalues/primitive_int_rvalue"/>
      </eGenericSuperTypes>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="system_variable" abstract="true">
      <eGenericSuperTypes eClassifier="#//variables/variable">
        <eTypeArguments eClassifier="#//rvalues/system_int_rvalue"/>
      </eGenericSuperTypes>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="collective_variable" abstract="true">
      <eGenericSuperTypes eClassifier="#//variables/variable">
        <eTypeArguments eClassifier="#//rvalues/collective_int_rvalue"/>
      </eGenericSuperTypes>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="functional_block" abstract="true"
        eSuperTypes="#//variables/system_variable"/>
    <eSubpackages name="primitive" nsURI="http://chips/variables/primitive" nsPrefix="chips.variables.primitive">
      <eClassifiers xsi:type="ecore:EClass" name="int" eSuperTypes="#//variables/primitive_variable">
        <eStructuralFeatures xsi:type="ecore:EReference" name="declaration" lowerBound="1"
            eType="#//statements/primitive/int_declaration" eOpposite="#//statements/primitive/int_declaration/variable"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="float" eSuperTypes="#//variables/primitive_variable">
        <eStructuralFeatures xsi:type="ecore:EReference" name="declaration" lowerBound="1"
            eType="#//statements/primitive/float_declaration" eOpposite="#//statements/primitive/float_declaration/variable"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="bool" eSuperTypes="#//variables/primitive_variable">
        <eStructuralFeatures xsi:type="ecore:EReference" name="declaration" lowerBound="1"
            eType="#//statements/primitive/bool_declaration" eOpposite="#//statements/primitive/bool_declaration/variable"/>
      </eClassifiers>
    </eSubpackages>
    <eSubpackages name="node" nsURI="http://chips/variables/node" nsPrefix="chips.variables.node">
      <eClassifiers xsi:type="ecore:EClass" name="contextual_variable" abstract="true"
          eSuperTypes="#//variables/node_variable"/>
      <eClassifiers xsi:type="ecore:EClass" name="int" eSuperTypes="#//variables/node/contextual_variable">
        <eStructuralFeatures xsi:type="ecore:EReference" name="declaration" lowerBound="1"
            eType="#//statements/node/contextual_int_declaration" eOpposite="#//statements/node/contextual_int_declaration/variable"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="float" eSuperTypes="#//variables/node/contextual_variable">
        <eStructuralFeatures xsi:type="ecore:EReference" name="declaration" lowerBound="1"
            eType="#//statements/node/contextual_float_declaration"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="bool" eSuperTypes="#//variables/node/contextual_variable">
        <eStructuralFeatures xsi:type="ecore:EReference" name="declaration" lowerBound="1"
            eType="#//statements/node/contextual_bool_declaration"/>
      </eClassifiers>
    </eSubpackages>
    <eSubpackages name="collective" nsURI="http://chips/variables/collective" nsPrefix="chips.variables.collective">
      <eClassifiers xsi:type="ecore:EClass" name="int" eSuperTypes="#//variables/collective_variable">
        <eStructuralFeatures xsi:type="ecore:EReference" name="declaration" lowerBound="1"
            eType="#//statements/collective/int_declaration" eOpposite="#//statements/collective/int_declaration/variable"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="float" eSuperTypes="#//variables/collective_variable">
        <eStructuralFeatures xsi:type="ecore:EReference" name="declaration" lowerBound="1"
            eType="#//statements/collective/float_declaration" eOpposite="#//statements/collective/float_declaration/variable"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="bool" eSuperTypes="#//variables/collective_variable">
        <eStructuralFeatures xsi:type="ecore:EReference" name="declaration" lowerBound="1"
            eType="#//statements/collective/bool_declaration" eOpposite="#//statements/collective/bool_declaration/variable"/>
      </eClassifiers>
    </eSubpackages>
    <eSubpackages name="system" nsURI="http://chips/variables/system" nsPrefix="chips.variables.system">
      <eClassifiers xsi:type="ecore:EClass" name="int" eSuperTypes="#//variables/system_variable">
        <eStructuralFeatures xsi:type="ecore:EReference" name="declaration" lowerBound="1"
            eType="#//statements/system/int_declaration" eOpposite="#//statements/system/int_declaration/variable"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="float" eSuperTypes="#//variables/system_variable">
        <eStructuralFeatures xsi:type="ecore:EReference" name="declaration" lowerBound="1"
            eType="#//statements/system/float_declaration" eOpposite="#//statements/system/float_declaration/variable"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="bool" eSuperTypes="#//variables/system_variable">
        <eStructuralFeatures xsi:type="ecore:EReference" name="declaration" lowerBound="1"
            eType="#//statements/system/bool_declaration" eOpposite="#//statements/system/bool_declaration/variable"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="logical" eSuperTypes="#//variables/functional_block">
        <eStructuralFeatures xsi:type="ecore:EReference" name="declaration" lowerBound="1"
            eType="#//statements/system/logical_declaration" eOpposite="#//statements/system/logical_declaration/variable"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="physical" eSuperTypes="#//variables/functional_block">
        <eStructuralFeatures xsi:type="ecore:EReference" name="declaration" lowerBound="1"
            eType="#//statements/system/physical_declaration" eOpposite="#//statements/system/physical_declaration/variable"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="object" eSuperTypes="#//variables/system_variable">
        <eStructuralFeatures xsi:type="ecore:EReference" name="declaration" lowerBound="1"
            eType="#//statements/system/object_declaration" eOpposite="#//statements/system/object_declaration/variable"/>
      </eClassifiers>
    </eSubpackages>
  </eSubpackages>
  <eSubpackages name="statements" nsURI="http://chips/statements" nsPrefix="chips.statements">
    <eClassifiers xsi:type="ecore:EClass" name="system_statement" abstract="true"/>
    <eClassifiers xsi:type="ecore:EClass" name="node_statement" abstract="true"/>
    <eClassifiers xsi:type="ecore:EClass" name="implementation_statement" abstract="true"/>
    <eClassifiers xsi:type="ecore:EClass" name="primitive_statement" abstract="true"
        eSuperTypes="#//statements/node_statement"/>
    <eClassifiers xsi:type="ecore:EClass" name="collective_statement" abstract="true"/>
    <eClassifiers xsi:type="ecore:EClass" name="primitive_declaration" abstract="true"
        eSuperTypes="#//statements/primitive_statement"/>
    <eClassifiers xsi:type="ecore:EClass" name="collective_declaration" abstract="true"
        eSuperTypes="#//statements/collective_statement"/>
    <eClassifiers xsi:type="ecore:EClass" name="system_declaration" abstract="true"
        eSuperTypes="#//statements/system_statement"/>
    <eSubpackages name="primitive" nsURI="http://chips/statements/primitive" nsPrefix="chips.statements.primitive">
      <eClassifiers xsi:type="ecore:EClass" name="int_declaration" eSuperTypes="#//statements/primitive_declaration">
        <eStructuralFeatures xsi:type="ecore:EReference" name="variable" lowerBound="1"
            eType="#//variables/primitive/int" containment="true" eOpposite="#//variables/primitive/int/declaration"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="float_declaration" eSuperTypes="#//statements/primitive_declaration">
        <eStructuralFeatures xsi:type="ecore:EReference" name="variable" lowerBound="1"
            eType="#//variables/primitive/float" containment="true" eOpposite="#//variables/primitive/float/declaration"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="bool_declaration" eSuperTypes="#//statements/primitive_declaration">
        <eStructuralFeatures xsi:type="ecore:EReference" name="variable" lowerBound="1"
            eType="#//variables/primitive/bool" containment="true" eOpposite="#//variables/primitive/bool/declaration"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="int_assignment" eSuperTypes="#//statements/primitive_statement">
        <eStructuralFeatures xsi:type="ecore:EReference" name="lvalue" lowerBound="1"
            eType="#//lvalues/primitive_int_lvalue" containment="true"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="rvalue" lowerBound="1"
            eType="#//rvalues/primitive_int_rvalue" containment="true"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="float_assignment" eSuperTypes="#//statements/primitive_statement">
        <eStructuralFeatures xsi:type="ecore:EReference" name="lvalue" lowerBound="1"
            eType="#//lvalues/primitive_float_lvalue" containment="true"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="rvalue" lowerBound="1"
            eType="#//rvalues/primitive_float_rvalue" containment="true"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="bool_assignment" eSuperTypes="#//statements/primitive_statement">
        <eStructuralFeatures xsi:type="ecore:EReference" name="lvalue" lowerBound="1"
            eType="#//lvalues/primitive_bool_lvalue" containment="true"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="rvalue" lowerBound="1"
            eType="#//rvalues/primitive_bool_rvalue" containment="true"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="if" eSuperTypes="#//statements/primitive_statement">
        <eStructuralFeatures xsi:type="ecore:EReference" name="condition" lowerBound="1"
            eType="#//rvalues/primitive_bool_rvalue" containment="true"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="if_section" eType="#//statements/primitive/if_section"
            containment="true"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="if_else" eSuperTypes="#//statements/primitive/if">
        <eStructuralFeatures xsi:type="ecore:EReference" name="else_section" eType="#//statements/primitive/else_section"
            containment="true"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="foreach" eSuperTypes="#//statements/primitive_statement">
        <eStructuralFeatures xsi:type="ecore:EReference" name="iterator" lowerBound="1"
            eType="#//statements/primitive_declaration" containment="true"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="iterable_expr" lowerBound="1"
            eType="#//rvalues/primitive_rvalue" containment="true"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="statements" upperBound="-1"
            eType="#//statements/primitive_statement" containment="true"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="if_section">
        <eStructuralFeatures xsi:type="ecore:EReference" name="if_statements" upperBound="-1"
            eType="#//statements/primitive_statement" containment="true"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="else_section">
        <eStructuralFeatures xsi:type="ecore:EReference" name="else_statements" upperBound="-1"
            eType="#//statements/primitive_statement" containment="true"/>
      </eClassifiers>
    </eSubpackages>
    <eSubpackages name="collective" nsURI="http://chips/statements/collective" nsPrefix="chips.statements.collective">
      <eClassifiers xsi:type="ecore:EClass" name="int_declaration" eSuperTypes="#//statements/collective_declaration">
        <eStructuralFeatures xsi:type="ecore:EReference" name="variable" lowerBound="1"
            eType="#//variables/collective/int" containment="true" eOpposite="#//variables/collective/int/declaration"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="float_declaration" eSuperTypes="#//statements/collective_declaration">
        <eStructuralFeatures xsi:type="ecore:EReference" name="variable" lowerBound="1"
            eType="#//variables/collective/float" containment="true" eOpposite="#//variables/collective/float/declaration"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="bool_declaration" eSuperTypes="#//statements/collective_declaration">
        <eStructuralFeatures xsi:type="ecore:EReference" name="variable" lowerBound="1"
            eType="#//variables/collective/bool" containment="true" eOpposite="#//variables/collective/bool/declaration"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="int_assignment" eSuperTypes="#//statements/collective_statement">
        <eStructuralFeatures xsi:type="ecore:EReference" name="lvalue" lowerBound="1"
            eType="#//lvalues/collective_int_lvalue" containment="true"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="rvalue" lowerBound="1"
            eType="#//rvalues/collective_int_rvalue" containment="true"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="float_assignment" eSuperTypes="#//statements/collective_statement">
        <eStructuralFeatures xsi:type="ecore:EReference" name="lvalue" lowerBound="1"
            eType="#//lvalues/collective_float_lvalue" containment="true"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="rvalue" lowerBound="1"
            eType="#//rvalues/collective_float_rvalue" containment="true"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="bool_assignment" eSuperTypes="#//statements/collective_statement">
        <eStructuralFeatures xsi:type="ecore:EReference" name="lvalue" lowerBound="1"
            eType="#//lvalues/collective_bool_lvalue" containment="true"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="rvalue" lowerBound="1"
            eType="#//rvalues/collective_bool_rvalue" containment="true"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="if" eSuperTypes="#//statements/collective_statement">
        <eStructuralFeatures xsi:type="ecore:EReference" name="condition" lowerBound="1"
            eType="#//rvalues/collective_bool_rvalue" containment="true"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="if_section" eType="#//statements/collective/if_section"
            containment="true"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="if_else" eSuperTypes="#//statements/collective/if">
        <eStructuralFeatures xsi:type="ecore:EReference" name="else_section" eType="#//statements/collective/else_section"
            containment="true"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="if_section">
        <eStructuralFeatures xsi:type="ecore:EReference" name="if_statements" upperBound="-1"
            eType="#//statements/collective_statement" containment="true"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="else_section">
        <eStructuralFeatures xsi:type="ecore:EReference" name="else_statements" upperBound="-1"
            eType="#//statements/collective_statement" containment="true"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="foreach" eSuperTypes="#//statements/collective_statement">
        <eStructuralFeatures xsi:type="ecore:EReference" name="iterator" lowerBound="1"
            eType="#//statements/collective_declaration" containment="true"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="iterable_expr" lowerBound="1"
            eType="#//rvalues/collective_rvalue" containment="true"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="statements" upperBound="-1"
            eType="#//statements/collective_statement" containment="true"/>
      </eClassifiers>
    </eSubpackages>
    <eSubpackages name="system" nsURI="http://chips/statements/system" nsPrefix="chips.statements.system">
      <eClassifiers xsi:type="ecore:EClass" name="logical_declaration" eSuperTypes="#//statements/system_declaration">
        <eStructuralFeatures xsi:type="ecore:EReference" name="variable" lowerBound="1"
            eType="#//variables/system/logical" containment="true" eOpposite="#//variables/system/logical/declaration"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="def" lowerBound="1"
            eType="#//definitions/logical_definition"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="physical_declaration" eSuperTypes="#//statements/system_declaration">
        <eStructuralFeatures xsi:type="ecore:EReference" name="variable" lowerBound="1"
            eType="#//variables/system/physical" containment="true" eOpposite="#//variables/system/physical/declaration"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="def" lowerBound="1"
            eType="#//definitions/physical_definition"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="object_declaration" eSuperTypes="#//statements/system_declaration">
        <eStructuralFeatures xsi:type="ecore:EReference" name="variable" lowerBound="1"
            eType="#//variables/system/object" containment="true" eOpposite="#//variables/system/object/declaration"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="def" lowerBound="1"
            eType="#//definitions/object_definition"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="int_declaration" eSuperTypes="#//statements/system_declaration">
        <eStructuralFeatures xsi:type="ecore:EReference" name="variable" lowerBound="1"
            eType="#//variables/system/int" containment="true" eOpposite="#//variables/system/int/declaration"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="float_declaration" eSuperTypes="#//statements/system_declaration">
        <eStructuralFeatures xsi:type="ecore:EReference" name="variable" lowerBound="1"
            eType="#//variables/system/float" containment="true" eOpposite="#//variables/system/float/declaration"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="bool_declaration" eSuperTypes="#//statements/system_declaration">
        <eStructuralFeatures xsi:type="ecore:EReference" name="variable" lowerBound="1"
            eType="#//variables/system/bool" containment="true" eOpposite="#//variables/system/bool/declaration"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="int_assignment" eSuperTypes="#//statements/system_statement">
        <eStructuralFeatures xsi:type="ecore:EReference" name="lvalue" lowerBound="1"
            eType="#//lvalues/system_int_lvalue" containment="true"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="rvalue" lowerBound="1"
            eType="#//rvalues/system_int_rvalue" containment="true"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="float_assignment" eSuperTypes="#//statements/system_statement">
        <eStructuralFeatures xsi:type="ecore:EReference" name="lvalue" lowerBound="1"
            eType="#//lvalues/system_float_lvalue" containment="true"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="rvalue" lowerBound="1"
            eType="#//rvalues/system_float_rvalue" containment="true"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="bool_assignment" eSuperTypes="#//statements/system_statement">
        <eStructuralFeatures xsi:type="ecore:EReference" name="lvalue" lowerBound="1"
            eType="#//lvalues/system_bool_lvalue" containment="true"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="rvalue" lowerBound="1"
            eType="#//rvalues/system_bool_rvalue" containment="true"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="if" eSuperTypes="#//statements/system_statement">
        <eStructuralFeatures xsi:type="ecore:EReference" name="condition" lowerBound="1"
            eType="#//rvalues/system_bool_rvalue" containment="true"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="if_section" eType="#//statements/system/if_section"
            containment="true"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="if_else" eSuperTypes="#//statements/system/if">
        <eStructuralFeatures xsi:type="ecore:EReference" name="else_section" eType="#//statements/system/else_section"
            containment="true"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="foreach" eSuperTypes="#//statements/system_statement">
        <eStructuralFeatures xsi:type="ecore:EReference" name="iterator" lowerBound="1"
            eType="#//statements/system_declaration" containment="true"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="iterable_expr" lowerBound="1"
            eType="#//rvalues/system_iterable" containment="true"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="statements" upperBound="-1"
            eType="#//statements/system_statement" containment="true"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="if_section">
        <eStructuralFeatures xsi:type="ecore:EReference" name="if_statements" upperBound="-1"
            eType="#//statements/system_statement" containment="true"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="else_section">
        <eStructuralFeatures xsi:type="ecore:EReference" name="else_statements" upperBound="-1"
            eType="#//statements/system_statement" containment="true"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="implements_statement" eSuperTypes="#//statements/system_statement">
        <eStructuralFeatures xsi:type="ecore:EReference" name="implemented" lowerBound="1"
            eType="#//systemspecific/interface" containment="true"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="implementer" lowerBound="1"
            eType="#//systemspecific/implementer" containment="true"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="implmentation" lowerBound="1"
            eType="#//definitions/implementation_definition"/>
      </eClassifiers>
      <eClassifiers xsi:type="ecore:EClass" name="channel_plugging" eSuperTypes="#//statements/system_statement">
        <eStructuralFeatures xsi:type="ecore:EReference" name="eater" lowerBound="1"
            eType="#//systemspecific/expressions/eater/channel_eater" containment="true"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="feeder" lowerBound="1"
