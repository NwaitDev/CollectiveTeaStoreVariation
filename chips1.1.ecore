          <eStructuralFeatures xsi:type="ecore:EReference" name="variable_expression"
              lowerBound="1" eType="#//systemspecific/expressions/logical_variable_expression"
              containment="true"/>
          <eStructuralFeatures xsi:type="ecore:EReference" name="parameter" lowerBound="1"
              eType="#//parameters/logical/int_logical_parameter"/>
